{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npx create-next-app@latest:*)",
      "Bash(claude mcp:*)",
      "Write(**/*.md)",
      "Edit(**/*.md)",
      "MultiEdit(**/*.md)",
      "Write(**/.claude/memory/**)",
      "Edit(**/.claude/memory/**)",
      "MultiEdit(**/.claude/memory/**)",
      "Write(/Users/*/.claude/projects/**/memory/**)",
      "Edit(/Users/*/.claude/projects/**/memory/**)",
      "MultiEdit(/Users/*/.claude/projects/**/memory/**)",
      "Write(/Users/**/memory/**)",
      "Edit(/Users/**/memory/**)",
      "MultiEdit(/Users/**/memory/**)",
      "Write(/home/**/memory/**)",
      "Edit(/home/**/memory/**)",
      "MultiEdit(/home/**/memory/**)",
      "Write(**/memory/**)",
      "Edit(**/memory/**)",
      "MultiEdit(**/memory/**)",
      "Write(**/MEMORY.md)",
      "Edit(**/MEMORY.md)",
      "MultiEdit(**/MEMORY.md)",
      "Write(.claude/memory/**)",
      "Edit(.claude/memory/**)",
      "MultiEdit(.claude/memory/**)",
      "Write(~/.claude/projects/**/memory/**)",
      "Edit(~/.claude/projects/**/memory/**)",
      "MultiEdit(~/.claude/projects/**/memory/**)",
      "mcp__pencil"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__claude_ai_ClickUp__clickup_",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-clickup-writes.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bash-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/destructive-ops-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/grounding-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/justify-source-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/model-router-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__voice-output__speak",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/voice-gate.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__claude-in-chrome__javascript_tool",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/validation-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__claude-in-chrome__|mcp__computer-use__",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/grounding-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent|Workflow",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-teams-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/model-router-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/memory-approve.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/content-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/justify-source-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.nyx/hook-bridge.cjs\" claude-code tool-start"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SESSION_CWD=\"$(pwd)\" ~/.claude/startup-check.sh",
            "timeout": 10,
            "statusMessage": "Loading memory..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/voice-mandate.sh",
            "timeout": 5,
            "statusMessage": "Checking voice output..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/team-reaper.sh session-start",
            "timeout": 5,
            "statusMessage": "Reaping orphaned teams..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/node-shim-heal.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.nyx/hook-bridge.cjs\" claude-code session-start"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sidecoach-sessionstart.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "SESSION_CWD=\"$(pwd)\" ~/.claude/hooks/sidecoach-preamble.sh",
            "timeout": 5,
            "statusMessage": "Loading project design context..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "SESSION_CWD=\"$(pwd)\" ~/.claude/hooks/reflect-nudge.sh",
            "timeout": 5,
            "statusMessage": "Checking reflection status..."
          },
          {
            "type": "command",
            "command": "SESSION_CWD=\"$(pwd)\" ~/.claude/hooks/consolidate-nudge.sh",
            "timeout": 5,
            "statusMessage": "Checking for consolidatable beat clusters..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/memory-compact.sh",
            "timeout": 5,
            "statusMessage": "Keeping the beats index under load budget..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/justify-watch-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking justify watch..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s' '{\"systemMessage\":\"PreCompact: flushing pending memory\",\"hookSpecificOutput\":{\"hookEventName\":\"PreCompact\",\"additionalContext\":\"PRE-COMPACT: Before this context compresses, write any pending session memory entries to .claude/memory/ per CLAUDE.md memory discipline. Do this NOW.\"}}'",
            "timeout": 5,
            "statusMessage": "Flushing memory before compact..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SESSION_CWD=\"$(pwd)\" ~/.claude/startup-check.sh",
            "timeout": 10,
            "statusMessage": "Reloading memory after compaction..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/voice-mandate.sh",
            "timeout": 5,
            "statusMessage": "Checking voice output..."
          },
          {
            "type": "command",
            "command": "SESSION_CWD=\"$(pwd)\" ~/.claude/hooks/sidecoach-preamble.sh",
            "timeout": 5,
            "statusMessage": "Reloading project design context..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/resume-toggle.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/voice-toggle.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/destructive-confirm-detect.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-manual.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/multiple-choice-inject-prompt.sh",
            "timeout": 5,
            "statusMessage": "Checking for multiple-choice violations..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/sidecoach-keyword.sh",
            "timeout": 5,
            "statusMessage": "Detecting sidecoach verbs..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/grounding-gate.sh",
            "timeout": 5,
            "statusMessage": "Grounding check (read code+beats before probing)..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.nyx/hook-bridge.cjs\" claude-code prompt-submit"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sidecoach-postuserp.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/memory-nudge.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-before-done.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/second-fix-gate.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/memory-compact.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/sidecoach-taste-gate.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "mcp__claude-in-chrome__javascript_tool|mcp__claude-in-chrome__read_page|mcp__claude-in-chrome__get_page_text|mcp__claude-in-chrome__navigate|mcp__claude-in-chrome__get_screenshot",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-clear.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.nyx/hook-bridge.cjs\" claude-code tool-end"
          }
        ]
      },
      {
        "matcher": "Bash|mcp__claude-in-chrome__computer",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/screenshot-open-mandate.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/screenshot-open-clear.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-before-done.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.nyx/hook-bridge.cjs\" claude-code notify"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.nyx/hook-bridge.cjs\" claude-code stop"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/node-shim-heal.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sidecoach-postresponse.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/multiple-choice-detect-stop.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/content-guard-stop.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/justify-watch-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.nyx/hook-bridge.cjs\" claude-code subagent-stop"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/resume-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/team-reaper.sh session-end",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.nyx/hook-bridge.cjs\" claude-code session-end"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "[ -x ~/.claude/statusline-command.sh ] && bash ~/.claude/statusline-command.sh || true"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "firebase@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": false,
    "semgrep@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "vercel@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "impeccable@impeccable": false,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      },
      "autoUpdate": true
    },
    "buildwithclaude": {
      "source": {
        "source": "github",
        "repo": "davepoon/buildwithclaude"
      },
      "autoUpdate": true
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "voice": {
    "enabled": true
  },
  "skipDangerousModePermissionPrompt": true,
  "verbose": true,
  "voiceEnabled": true,
  "mcpServers": {
    "voice-output": {
      "command": "node",
      "args": [
        "${HOME}/.claude/voice-output/server.js"
      ]
    },
    "justify": {
      "command": "node",
      "args": [
        "${HOME}/.claude/justify/dist/server/index.js"
      ]
    },
    "peekaboo": {
      "command": "/opt/homebrew/bin/peekaboo",
      "args": [
        "mcp",
        "serve"
      ]
    }
  },
  "agentPushNotifEnabled": true
}