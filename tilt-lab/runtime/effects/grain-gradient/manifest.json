{
  "id": "grain-gradient",
  "name": "Grain Gradient",
  "category": "generative-gradient",
  "layerRole": "background",
  "params": [
    { "name": "preset", "type": "select", "default": "Default", "options": ["Default", "Wave", "Dots", "Truchet", "Ripple", "Blob", "Custom"] },
    { "name": "color1", "type": "color", "default": "#7300ff" },
    { "name": "color2", "type": "color", "default": "#eba8ff" },
    { "name": "color3", "type": "color", "default": "#00bfff" },
    { "name": "color4", "type": "color", "default": "#2a00ff" },
    { "name": "color5", "type": "color", "default": "#7300ff" },
    { "name": "color6", "type": "color", "default": "#eba8ff" },
    { "name": "color7", "type": "color", "default": "#00bfff" },
    { "name": "colorsCount", "type": "range", "default": 4, "min": 1, "max": 7, "step": 1 },
    { "name": "colorBack", "type": "color", "default": "#000000" },
    { "name": "shape", "type": "select", "default": "corners", "options": ["wave", "dots", "truchet", "corners", "ripple", "blob", "sphere"] },
    { "name": "softness", "type": "range", "default": 0.5, "min": 0, "max": 1, "step": 0.01 },
    { "name": "intensity", "type": "range", "default": 0.5, "min": 0, "max": 1, "step": 0.01 },
    { "name": "noise", "type": "range", "default": 0.25, "min": 0, "max": 1, "step": 0.01 },
    { "name": "speed", "type": "range", "default": 1, "min": -2, "max": 2, "step": 0.1 },
    { "name": "scale", "type": "range", "default": 1, "min": 0.01, "max": 4, "step": 0.01 },
    { "name": "rotation", "type": "range", "default": 0, "min": 0, "max": 360, "step": 1 },
    { "name": "offsetX", "type": "range", "default": 0, "min": -1, "max": 1, "step": 0.01 },
    { "name": "offsetY", "type": "range", "default": 0, "min": -1, "max": 1, "step": 0.01 },
    { "name": "originX", "type": "range", "default": 0.5, "min": 0, "max": 1, "step": 0.01 },
    { "name": "originY", "type": "range", "default": 0.5, "min": 0, "max": 1, "step": 0.01 },
    { "name": "worldWidth", "type": "range", "default": 0, "min": 0, "max": 5000, "step": 1 },
    { "name": "worldHeight", "type": "range", "default": 0, "min": 0, "max": 5000, "step": 1 },
    { "name": "fit", "type": "select", "default": "contain", "options": ["none", "contain", "cover"] }
  ],
  "requiredAssets": ["noiseTexture"],
  "origin": "https://github.com/paper-design/shaders (@paper-design/shaders 0.0.76)",
  "license": "PolyForm Shield License 1.0.0",
  "attribution": "Paper Design (github.com/paper-design/shaders)",
  "redistribution": "ok",
  "tags": ["webgl2", "gradient", "grain", "noise", "multi-shape", "animated", "background"]
}
