{
  "id": "fractal-glass-post",
  "name": "Fractal Glass (Post)",
  "category": "post-process",
  "layerRole": "post",
  "params": [
    { "name": "scene", "type": "select", "default": "Indicium", "options": ["Indicium", "Violet Abyss", "Emerald Depth", "Crimson Forge", "Regent", "Custom"] },
    { "name": "baseColor1", "type": "color", "default": "#030618" },
    { "name": "baseColor2", "type": "color", "default": "#1040a0" },
    { "name": "baseColor3", "type": "color", "default": "#78b0dc" },
    { "name": "baseColor4", "type": "color", "default": "#A0C4E8" },
    { "name": "autoEnv", "type": "toggle", "default": true },
    { "name": "envColor1", "type": "color", "default": "#030620" },
    { "name": "envColor2", "type": "color", "default": "#1248b0" },
    { "name": "envColor3", "type": "color", "default": "#68a0d0" },
    { "name": "fluidInfluence", "type": "range", "default": 0.3, "min": 0, "max": 1, "step": 0.01 },
    { "name": "turbulence", "type": "range", "default": 0.1, "min": 0, "max": 1, "step": 0.01 },
    { "name": "glassAmount", "type": "range", "default": 0.5, "min": 0, "max": 1, "step": 0.01 },
    { "name": "highlight", "type": "range", "default": 1.0, "min": 0.1, "max": 2, "step": 0.01 },
    { "name": "midtone", "type": "range", "default": 1.0, "min": 0.1, "max": 2, "step": 0.01 },
    { "name": "shadow", "type": "range", "default": 1.0, "min": 0.1, "max": 2, "step": 0.01 },
    { "name": "fluteCount", "type": "range", "default": 50, "min": 2, "max": 100, "step": 1 },
    { "name": "fluteExponent", "type": "range", "default": 2.0, "min": 1.8, "max": 4, "step": 0.1 },
    { "name": "fluteDepth", "type": "range", "default": 1.0, "min": 0, "max": 1, "step": 0.01 },
    { "name": "ior", "type": "range", "default": 1.3, "min": 1.0, "max": 2.5, "step": 0.01 },
    { "name": "thickness", "type": "range", "default": 0.1, "min": 0.01, "max": 0.5, "step": 0.01 },
    { "name": "roughness", "type": "range", "default": 0, "min": 0, "max": 1, "step": 0.01 },
    { "name": "envIntensity", "type": "range", "default": 1.0, "min": 0, "max": 3, "step": 0.01 },
    { "name": "bloomStrength", "type": "range", "default": 0.3, "min": 0, "max": 1, "step": 0.01 }
  ],
  "requiredAssets": [],
  "origin": "https://github.com/regent (fractal-glass); post-overlay variant refracts the composited layers beneath it",
