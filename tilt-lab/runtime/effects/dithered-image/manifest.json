{
  "id": "dithered-image",
  "name": "Dithered Image",
  "category": "post",
  "layerRole": "post",
  "params": [
    { "name": "ditherMap", "type": "select", "default": "bayer4x4", "options": ["bayer4x4", "bayer8x8"] },
    { "name": "pixelSize", "type": "range", "default": 1, "min": 1, "max": 16, "step": 1 },
    { "name": "threshold", "type": "range", "default": 0, "min": -0.5, "max": 0.5, "step": 0.01 },
    { "name": "color", "type": "color", "default": "#ff6900" },
    { "name": "backgroundColor", "type": "color", "default": "#17181A" }
  ],
  "requiredAssets": ["src"],
